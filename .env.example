PEXELS_API_KEY=

# YouTube cookies (avoids "Sign in to confirm you're not a bot"). Use ONE of:
# 1) Cookies file (recommended): install "Get cookies.txt LOCALLY" in Chrome, open youtube.com, export → save as cookies.txt, then:
#    YTDL_COOKIES_FILE=./cookies.txt
# 2) Browser name (Chrome must be closed on macOS so yt-dlp can read the DB):
#    YTDL_COOKIES_BROWSER=chrome

# Posición del vídeo en pantalla: full (toda), top_half (mitad superior), bottom_half (mitad inferior)
